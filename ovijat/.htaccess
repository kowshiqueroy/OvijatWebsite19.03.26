Options -Indexes

# ============================================================
# ROOT .htaccess — Ovijat Food & Beverage
# Works on XAMPP (htdocs/ovijat/) and live server root
# ============================================================

# --- Security Headers ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- Block config and setup from direct HTTP access ---
<Files "config.php">
    Require all denied
</Files>
<Files "setup.php">
    Require all denied
</Files>

# No RewriteRules needed - all pages use direct .php URLs

# --- Cache static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg             "access plus 1 month"
    ExpiresByType image/png              "access plus 1 month"
    ExpiresByType image/webp             "access plus 1 month"
    ExpiresByType text/css               "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/x-icon           "access plus 1 year"
</IfModule>

# --- Compress text assets ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json
</IfModule>
